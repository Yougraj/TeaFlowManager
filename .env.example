# 1. MongoDB Connection: Replace with your actual MongoDB Cluster URI
MONGODB_URI=mongodb+srv://admin:password@cluster.mongodb.net/teaflow?retryWrites=true&w=majority

# 2. Serverless: This app uses 'serverless-http' to run on Netlify Functions.
# All /api/* requests are proxied via netlify.toml to /.netlify/functions/api

# 3. Firebase Configuration: Get these from your Firebase Console
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
