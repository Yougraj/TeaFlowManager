# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MongoDB Atlas Connection String
# Example: mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/teaflow?retryWrites=true&w=majority
# IMPORTANT: When deploying to Netlify, add this variable in the Netlify Dashboard (Site Settings > Environment variables)
MONGODB_URI=mongodb+srv://Yougraj:ijiwy45riw@cluster0.s9i58qs.mongodb.net/

# NETLIFY DEPLOYMENT NOTES:
# 1. IP Whitelisting: In MongoDB Atlas, you MUST allow access from anywhere (0.0.0.0/0) 
#    because Netlify Functions use dynamic IP addresses.
# 2. Serverless: This app uses 'serverless-http' to run on Netlify Functions.
# 3. Persistence: The local 'db_fallback.json' will not persist data on Netlify. 
#    A MongoDB connection is REQUIRED for production data persistence.

